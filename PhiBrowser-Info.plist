<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ATSApplicationFontsPath</key>
	<string>Fonts</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>XHTML document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.xhtml</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>HTML document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.html</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>PDF document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
		</dict>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Web site URL</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>http</string>
				<string>https</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>Phi</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>phi</string>
				<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			</array>
		</dict>
	</array>
	<key>Chromium version</key>
	<string>144.0.7559.102</string>
	<key>CrProductDirName</key>
	<string>$(CR_PRODUCT_DIR_NAME)</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>LSRequiresNativeExecution</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSRequiresAquaSystemAppearance</key>
	<false/>
	<key>NSUserActivityTypes</key>
	<array>
		<string>NSUserActivityTypeBrowsingWeb</string>
	</array>
	<key>SUAutomaticallyUpdate</key>
	<true/>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUFeedURL</key>
	<string>$(SUFEED_URL)</string>
	<key>SUPublicEDKey</key>
	<string>$(SPARKLE_PUBLIC_KEY)</string>
	<key>SUScheduledCheckInterval</key>
	<integer>7200</integer>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Websites may use your bluetooth for features on their site.</string>
	<key>NSCameraUsageDescription</key>
	<string>Websites may use your camera for features on their site.</string>
	<key>NSDesktopFolderUsageDescription</key>
	<string>Access to &quot;Desktop&quot; is required to make files accessible from Phi.</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>Access to &quot;Downloads&quot; is required for downloading files from the web and to make files accessible from Phi.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Websites may use your location for features on their site.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Websites may use your location for features on their site.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Websites may use your location for features on their site.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Websites may use your microphone for features on their site.</string>
</dict>
</plist>
