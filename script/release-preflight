#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION="${1:-}"

[[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
  echo "Usage: $0 X.Y.Z" >&2
  exit 2
}
[[ -z "$(git -C "$ROOT_DIR" status --porcelain)" ]] || {
  echo "Release preflight requires a clean working tree." >&2
  exit 1
}

grep -q 'PRODUCT_NAME = Lua' "$ROOT_DIR/Configs/Release.xcconfig"
grep -q 'PRODUCT_BUNDLE_IDENTIFIER = dev.jow.LuaBrowser' "$ROOT_DIR/Configs/Release.xcconfig"
grep -q 'ASSETCATALOG_COMPILER_APPICON_NAME = LuaIcon' "$ROOT_DIR/Configs/Release.xcconfig"
grep -q 'CR_PRODUCT_DIR_NAME = com.ojowwalker77.PhiBrowser' "$ROOT_DIR/Configs/Release.xcconfig"
grep -q 'CR_PRODUCT_DIR_NAME = ${PRODUCT_BUNDLE_IDENTIFIER}' "$ROOT_DIR/Configs/Shared.xcconfig"
grep -q 'PRODUCT_BUNDLE_IDENTIFIER = dev.jow.LuaBrowser.Development' "$ROOT_DIR/Configs/OpenSource.xcconfig"
grep -q 'github.com/ojowwalker77/phibrowser-mac/releases/latest/download/appcast.xml' "$ROOT_DIR/Configs/Release.xcconfig"
grep -q 'DEFAULT_SHA256="[0-9a-f]\{64\}"' "$ROOT_DIR/script/fetch_phi_framework.sh"
grep -Fq 'ln -s /Applications "$RUNNER_TEMP/dmg-root/Applications"' \
  "$ROOT_DIR/.github/workflows/release.yml"

if grep -R -E 'ota\.phibrowser\.com|account\.phibrowser\.com|ai\.phibrowser\.com' \
  "$ROOT_DIR/Configs" "$ROOT_DIR/Resources" "$ROOT_DIR/Sources"; then
  echo "Forbidden upstream service endpoint found." >&2
  exit 1
fi

LC_ALL=C sort -c "$ROOT_DIR/script/framework-endpoint-allowlist.txt"

echo "Lua Browser $VERSION is ready for release validation."
